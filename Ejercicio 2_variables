# 4. Declara 5 como numeroUno y 4 como numeroDos
numeroUno = 5
numeroDos = 4

# 5. Suma numeroUno y numeroDos y asigna el resultado a total
total = numeroUno + numeroDos
print('Total:', total)

# 6. Resta numeroDos de numeroUno y asigna el resultado a diferencia
diferencia = numeroUno - numeroDos
print('Diferencia:', diferencia)

# 7. Multiplica numeroUno por numeroDos y asigna el resultado a producto
producto = numeroUno * numeroDos
print('Producto:', producto)

# 8. Divide numeroUno por numeroDos y asigna el resultado a division
